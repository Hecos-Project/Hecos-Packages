# =============================================================================
#  Hecos-Packages — .gitignore
#  Source folders (*_src) stay LOCAL ONLY.
#  Everything else (builder, compiled packages, docs, assets) is tracked.
# =============================================================================

# ── Source folders: LOCAL ONLY — never push to GitHub ─────────────────────
# These contain raw plugin source code compiled locally.
# We ignore the contents, BUT allow metadata and preview files for the Store.
*_src/*

# Eccezioni: i file che servono allo Store vengono SEMPRE tracciati!
!*_src/preview*.png
!*_src/preview*.jpg
!*_src/preview*.jpeg
!*_src/preview*.gif
!*_src/README.md
!*_src/hpkg_manifest.toml

# ── Private signing key (CRITICAL — never push) ───────────────────────────
hpm_private.pem
*.pem

# ── Python cache ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.mypy_cache/
.ruff_cache/

# ── Environments ──────────────────────────────────────────────────────────
.venv/
venv/
env/

# ── OS / Editor junk ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.log
*.tmp
