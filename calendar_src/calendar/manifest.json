{
    "extension_id": "calendar",
    "parent_plugin": "WEB_UI",
    "display_name": "ext_calendar_title",
    "version": "1.0.0",
    "description": "ext_calendar_desc",
    "sidebar_widget": true,
    "visible": false,
    "room_visible": true,
    "room_span": 2,
    "room_height": "350px",
    "eager_load": true,
    "styles": ["static/css/calendar.css"],
    "config_schema": {
        "calendar_locale": {
            "type": "string",
            "default": "it",
            "description": "Date format locale (e.g., 'it' for Italian, 'en-gb' for UK English) for the visual calendar."
        },
        "calendar_country": {
            "type": "string",
            "default": "IT",
            "description": "ISO Country code for public holidays (e.g., 'IT', 'US', 'FR')."
        },
        "day_colors": {
            "type": "object",
            "default": {
                "0": "rgba(231, 76, 60, 0.1)",
                "5": "rgba(46, 204, 113, 0.08)"
            },
            "description": "Background colors for days of the week (0=Sun, 1=Mon, ..., 6=Sat)."
        }
    },
    "required_plugin": "CALENDAR"
}
